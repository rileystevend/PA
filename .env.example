ANTHROPIC_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
OPENWEATHER_API_KEY=
USER_LOCATION=Austin,TX,US
# Statesman uses Hearst OIDC — extract cookies from Chrome after logging in manually.
# DevTools → Application → Cookies → https://www.statesman.com
# Session lasts days to weeks; re-extract when Statesman news stops working.
STATESMAN_COOKIE_HNPAUTHS=
STATESMAN_COOKIE_HNPAUTHP=
STATESMAN_COOKIE_HNPDIUDPF1=
STATESMAN_COOKIE_HNPDIUDPF2=

# ── Tailscale / mobile access ─────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# First visit from phone: http://<tailscale-ip>:8000/?token=<ACCESS_TOKEN>
# That sets a 30-day cookie — no token needed after that.
ACCESS_TOKEN=
